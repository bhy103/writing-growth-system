generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum SubmissionSourceType {
  TYPED_TEXT
  PHOTO
  IMAGE_UPLOAD
  DOCUMENT_UPLOAD
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  ANALYZED
  REVISING
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  passwordSalt String?
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile StudentProfile?
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  gradeLevel     String?
  nativeLanguage String?  @default("zh-CN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions WritingSubmission[]
}

model WritingSubmission {
  id         String               @id @default(cuid())
  studentId  String
  title      String
  content    String?
  sourceType SubmissionSourceType @default(TYPED_TEXT)
  status     SubmissionStatus     @default(DRAFT)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  student   StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  analysis  WritingAnalysis?
  revisions Revision[]
  uploads   UploadAsset[]
}

model WritingAnalysis {
  id                 String   @id @default(cuid())
  submissionId       String   @unique
  overallLevel       String
  focusDimension     String
  strongestDimension String?
  weakestDimension   String?
  rubricJson         Json
  studentFeedback    String?
  parentSummaryZh    String?
  createdAt          DateTime @default(now())

  submission WritingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Revision {
  id           String   @id @default(cuid())
  submissionId String
  content      String
  note         String?
  createdAt    DateTime @default(now())

  submission WritingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model UploadAsset {
  id                   String   @id @default(cuid())
  submissionId          String?
  fileName              String
  fileType              String
  fileSize              Int?
  storagePath           String
  extractionConfidence  Float?
  extractedText         String?
  createdAt             DateTime @default(now())

  submission WritingSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
}
